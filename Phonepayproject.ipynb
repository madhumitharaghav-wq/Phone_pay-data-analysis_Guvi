      "source": [
        "# Stream and append the DataFrame data directly into the table\n",
        "Map_users_renamed = Map_users.rename(columns={\n",
        "    'State': 'state',\n",
        "    'Year': 'year',\n",
        "    'Quater': 'quarter',\n",
        "    'Region_name': 'region_name',\n",
        "    'Registered_Users': 'registered_users' # Changed to all lowercase 'registered_users'\n",
        "})\n",
        "Map_users_renamed.to_sql(name=\"regional_engagement\",con=engine,if_exists=\"append\",index=False,  # Skip Pandas index so 'id' handles auto-incrementing\n",
        ")\n",
        "\n",
        "print(\"Table verified and DataFrame successfully exported to PostgreSQL!\")"
      ]
