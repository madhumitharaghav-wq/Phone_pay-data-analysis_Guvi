    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lGoOnbtk_aUQ"
      },
      "source": [
        "3.2 Top 10 states / districts / pin codes where most number of users registered from, for a selected year-quarter combination."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 294,
      "metadata": {
        "id": "lIkDt-iu_fNg"
      },
      "outputs": [],
      "source": [
        "\n",
        "\n",
        "# 1. Update your base path to point to the Top User directory\n",
        "base_path = \"/content/pulse/data/top/user/country/india/\"\n",
        "\n",
        "# 2. Initialize three separate dictionaries for the user geographic layers\n",
        "top_user_states = {'Country': [], 'Year': [], 'Quarter': [], 'State_Name': [], 'Registered_Users': []}\n",
        "top_user_districts = {'Country': [], 'Year': [], 'Quarter': [], 'District_Name': [], 'Registered_Users': []}\n",
        "top_user_pincodes = {'Country': [], 'Year': [], 'Quarter': [], 'Pincode': [], 'Registered_Users': []}\n",
        "\n",
        "# Get year directories dynamically\n",
        "year_directories = [d for d in os.listdir(base_path) if os.path.isdir(os.path.join(base_path, d)) and d.isdigit()]\n",
        "\n",
        "# 3. Execute the loop through your files\n",
        "for year in year_directories:\n",
        "    year_path = os.path.join(base_path, year)\n",
        "\n",
        "    # Get the quarter json files directly inside the year folder\n",
        "    quarter_json_files = [f for f in os.listdir(year_path) if f.endswith('.json') and f.replace('.json', '').isdigit()]\n",
        "\n",
        "    for quarter_file in quarter_json_files:\n",
        "        full_file_path = os.path.join(year_path, quarter_file)\n",
        "        quarter_num = int(quarter_file.replace('.json', ''))\n",
        "\n",
        "        with open(full_file_path, 'r') as f:\n",
        "            D = json.load(f)\n",
        "\n",
        "            # Safe check to see if 'data' block exists\n",
        "            if D.get('data'):\n",
        "                data_block = D['data']\n",
        "\n",
        "                # --- SECTION A: TOP USER STATES ---\n",
        "                if data_block.get('states'):\n",
        "                    for z in data_block['states']:\n",
        "                        top_user_states['Country'].append('India')\n",
        "                        top_user_states['Year'].append(int(year))\n",
        "                        top_user_states['Quarter'].append(quarter_num)\n",
        "                        # Direct access: 'name' and 'registeredUsers' are on the main dictionary layer\n",
        "                        top_user_states['State_Name'].append(z['name'])\n",
        "                        top_user_states['Registered_Users'].append(z['registeredUsers'])\n",
        "\n",
        "                # --- SECTION B: TOP USER DISTRICTS ---\n",
        "                if data_block.get('districts'):\n",
        "                    for z in data_block['districts']:\n",
        "                        top_user_districts['Country'].append('India')\n",
        "                        top_user_districts['Year'].append(int(year))\n",
        "                        top_user_districts['Quarter'].append(quarter_num)\n",
        "                        top_user_districts['District_Name'].append(z['name'])\n",
        "                        top_user_districts['Registered_Users'].append(z['registeredUsers'])\n",
        "\n",
        "                # --- SECTION C: TOP USER PINCODES ---\n",
        "                if data_block.get('pincodes'):\n",
        "                    for z in data_block['pincodes']:\n",
        "                        top_user_pincodes['Country'].append('India')\n",
        "                        top_user_pincodes['Year'].append(int(year))\n",
        "                        top_user_pincodes['Quarter'].append(quarter_num)\n",
        "                        top_user_pincodes['Pincode'].append(z['name'])\n",
        "                        top_user_pincodes['Registered_Users'].append(z['registeredUsers'])\n",
        "\n",
        "# 4. Create DataFrames from the populated maps\n",
        "df_top_user_states = pd.DataFrame(top_user_states)\n",
        "df_top_user_districts = pd.DataFrame(top_user_districts)\n",
        "df_top_user_pincodes = pd.DataFrame(top_user_pincodes)\n",
        "\n"
      ]
    },
