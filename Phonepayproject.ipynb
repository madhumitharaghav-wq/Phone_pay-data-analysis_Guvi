      },
      "outputs": [],
      "source": [
        "clm={'State':[], 'Year':[],'Quater':[], 'Total_Registered_Users':[], 'Total_App_Opens':[], 'Brand':[], 'User_count':[], 'Percentage':[]}\n",
        "\n",
        "for i in Agg_state_list1:\n",
        "    p_i=path+i+\"/\"\n",
        "    Agg_yr1=os.listdir(p_i)\n",
        "    for j in Agg_yr1:\n",
        "        p_j=p_i+j+\"/\"\n",
        "        Agg_yr_list1=os.listdir(p_j)\n",
        "        for k in Agg_yr_list1:\n",
        "            p_k=p_j+k\n",
        "            Data=open(p_k,'r')\n",
        "            D=json.load(Data)\n",
        "\n",
        "            # Safely get 'data' dictionary, defaulting to an empty dict if not found\n",
        "            data_content = D.get('data', {})\n",
        "\n",
        "            # Safely get 'aggregated' data, defaulting to an empty dict if not found\n",
        "            aggregated_data = data_content.get('aggregated', {})\n",
        "\n",
        "            # Retrieve total users and app opens from 'aggregated_data'\n",
        "            reg_users = aggregated_data.get('registeredUsers')\n",
        "            app_opens = aggregated_data.get('appOpens')\n",
        "\n",
        "            # Safely get 'usersByDevice' data, which could be None or an empty list\n",
        "            users_by_device = data_content.get('usersByDevice')\n",
        "\n",
        "            if users_by_device: # Checks if users_by_device is not None and not empty\n",
        "                for z in users_by_device:\n",
        "                    brand = z['brand']\n",
        "                    count = z['count']\n",
        "                    percentage = z['percentage']\n",
        "                    clm['Total_Registered_Users'].append(reg_users)\n",
        "                    clm['Total_App_Opens'].append(app_opens)\n",
        "                    clm['Brand'].append(brand)\n",
        "                    clm['User_count'].append(count)\n",
        "                    clm['Percentage'].append(percentage)\n",
        "                    clm['State'].append(i)\n",
        "                    clm['Year'].append(j)\n",
        "                    clm['Quater'].append(int(k.strip('.json')))\n",
        "            else:\n",
        "                # If usersByDevice is not present or empty, append a single record with None for device details\n",
        "                clm['State'].append(i)\n",
        "                clm['Year'].append(j)\n",
        "                clm['Quater'].append(int(k.strip('.json')))\n",
        "                clm['Total_Registered_Users'].append(reg_users)\n",
        "                clm['Total_App_Opens'].append(app_opens)\n",
        "                clm['Brand'].append(None)\n",
        "                clm['User_count'].append(None)\n",
        "                clm['Percentage'].append(None)\n",
        "\n",
        "#Succesfully created a dataframe\n",
        "Agg_userdata=pd.DataFrame(clm)"
      ]
    },
