      "source": [
        "import pandas as pd\n",
        "import json\n",
        "import os\n",
        "from sqlalchemy import text\n",
        "\n",
        "with engine.connect() as conn:\n",
        "\n",
        "    conn.commit()\n",
        "\n",
        "# Create table if not exists for top_tran_states\n",
        "create_table_sql_states = \"\"\"\n",
        "    CREATE TABLE IF NOT EXISTS top_transac_states (\n",
        "        id SERIAL PRIMARY KEY,\n",
        "        state_folder TEXT NOT NULL,\n",
        "        year INTEGER NOT NULL,\n",
        "        quarter INTEGER NOT NULL,\n",
        "        top_state_name TEXT NOT NULL,\n",
        "        transaction_count BIGINT DEFAULT 0,\n",
        "        transaction_amount REAL DEFAULT 0.0\n",
        "    );\n",
        "    \"\"\"\n",
        "\n",
        "# Create table if not exists for top_trans_districts\n",
        "create_table_sql_districts = \"\"\"\n",
        "    CREATE TABLE IF NOT EXISTS top_transac_districts (\n",
        "        id SERIAL PRIMARY KEY,\n",
        "        state_folder TEXT NOT NULL,\n",
        "        year INTEGER NOT NULL,\n",
        "        quarter INTEGER NOT NULL,\n",
        "        district_name TEXT NOT NULL,\n",
        "        transaction_count BIGINT DEFAULT 0,\n",
        "        transaction_amount REAL DEFAULT 0.0\n",
        "    );\n",
        "    \"\"\"\n",
        "\n",
        "# Create table if not exists for top_trans_pincodes\n",
        "create_table_sql_pincodes = \"\"\"\n",
        "     CREATE TABLE IF NOT EXISTS top_transac_pincodes (\n",
        "        id SERIAL PRIMARY KEY,\n",
        "        state_folder TEXT NOT NULL,\n",
        "        year INTEGER NOT NULL,\n",
        "        quarter INTEGER NOT NULL,\n",
        "        pincode TEXT NOT NULL,\n",
        "        transaction_count BIGINT DEFAULT 0,\n",
        "        transaction_amount REAL DEFAULT 0.0\n",
        "    );\n",
        "    \"\"\"\n",
        "\n",
        "with engine.connect() as conn:\n",
        "    conn.execute(text(create_table_sql_states))\n",
        "    conn.execute(text(create_table_sql_districts))\n",
        "    conn.execute(text(create_table_sql_pincodes))\n",
        "    conn.commit()\n",
        "\n",
        "# Rename DataFrame columns to match PostgreSQL table schema before insertion\n",
        "# For df_top_states\n",
        "df_top_states_renamed = df_top_states.rename(columns={\n",
        "    'State_Folder': 'state_folder',\n",
        "    'Year': 'year',\n",
        "    'Quarter': 'quarter',\n",
        "    'Top_State_Name': 'top_state_name',\n",
        "    'Count': 'transaction_count',\n",
        "    'Amount': 'transaction_amount'\n",
        "})\n",
        "\n",
        "# For df_top_districts\n",
        "df_top_districts_renamed = df_top_districts.rename(columns={\n",
        "    'State_Folder': 'state_folder',\n",
        "    'Year': 'year',\n",
        "    'Quarter': 'quarter',\n",
        "    'District_Name': 'district_name',\n",
        "    'Count': 'transaction_count',\n",
        "    'Amount': 'transaction_amount'\n",
        "})\n",
        "\n",
        "# For df_top_pincodes\n",
        "df_top_pincodes_renamed = df_top_pincodes.rename(columns={\n",
        "    'State_Folder': 'state_folder',\n",
        "    'Year': 'year',\n",
        "    'Quarter': 'quarter',\n",
        "    'Pincode': 'pincode',\n",
        "    'Count': 'transaction_count',\n",
        "    'Amount': 'transaction_amount'\n",
        "})\n",
        "\n",
        "# Stream and append the DataFrame data directly into the table\n",
        "df_top_states_renamed.to_sql(name=\"top_transaction_states\",con=engine,if_exists=\"append\",index=False)\n",
        "df_top_districts_renamed.to_sql(name=\"top_transaction_districts\",con=engine,if_exists=\"append\",index=False)\n",
        "df_top_pincodes_renamed.to_sql(name=\"top_transaction_pincodes\",con=engine,if_exists=\"append\",index=False)\n",
        "\n",
        "print(\"Table 'top_transaction_states' verified and DataFrame successfully exported to PostgreSQL!\")\n",
        "print(\"Table 'top_transaction_districts' verified and DataFrame successfully exported to PostgreSQL!\")\n",
        "print(\"Table 'top_transaction_pincodes' verified and DataFrame successfully exported to PostgreSQL!\")\n",
        "\n",
        "# Query the tables to verify the data\n",
        "query_states = \"SELECT * FROM top_transaction_states;\"\n",
        "df_top_transaction_states = pd.read_sql(query_states, engine)\n",
        "\n",
        "query_districts = \"SELECT * FROM top_transaction_districts;\"\n",
