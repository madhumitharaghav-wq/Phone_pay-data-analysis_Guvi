        },
        "outputId": "49c74033-a870-41ce-9cc1-80e3f3871b52"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Table verified and DataFrame successfully exported to PostgreSQL!\n"
          ]
        }
      ],
      "source": [
        "# Stream and append the DataFrame data directly into the table\n",
        "Map_insurance.to_sql(name=\"map_insurance_data\",con=engine,if_exists=\"append\",index=False,  # Skip Pandas index so 'id' handles auto-incrementing\n",
        ")\n",
        "\n",
        "print(\"Table verified and DataFrame successfully exported to PostgreSQL!\")"
      ]
