      "source": [
        "3. TOP\n",
        "3.1 Top 10 states / districts / pin codes where the most number of the transactions happened for a selected year-quarter combination.\n",
        "\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 290,
      "metadata": {
        "id": "4nzrVqcp5Wio"
      },
      "outputs": [],
      "source": [
        "\n",
        "state_data = {'State_Folder': [], 'Year': [], 'Quarter': [], 'Top_State_Name': [], 'Count': [], 'Amount': []}\n",
        "district_data = {'State_Folder': [], 'Year': [], 'Quarter': [], 'District_Name': [], 'Count': [], 'Amount': []}\n",
        "pincode_data = {'State_Folder': [], 'Year': [], 'Quarter': [], 'Pincode': [], 'Count': [], 'Amount': []}\n",
        "\n",
        "base_path = \"/content/pulse/data/top/transaction/country/india/\"\n",
        "\n",
        "year_directories = [d for d in os.listdir(base_path) if os.path.isdir(os.path.join(base_path, d)) and d.isdigit()]\n",
        "\n",
        "for year in year_directories: # Loop through years (e.g., '2019', '2022')\n",
        "    year_path = os.path.join(base_path, year)\n",
        "\n",
        "    # Corrected: Assume quarter files are directly inside the year directory, e.g., '1.json', '2.json'\n",
        "    quarter_json_files = [f for f in os.listdir(year_path) if f.endswith('.json') and f.strip('.json').isdigit()]\n",
        "\n",
        "    for quarter_file in quarter_json_files: # Loop through quarter JSON files\n",
        "        full_file_path = os.path.join(year_path, quarter_file)\n",
        "        quarter_num = int(quarter_file.strip('.json'))\n",
        "\n",
        "        # Load the JSON data for the quarter\n",
        "        with open(full_file_path, 'r') as f:\n",
        "            D = json.load(f)\n",
        "\n",
        "        # --- SECTION A: TOP STATES ---\n",
        "        # Check if 'data' and 'states' list exist and are not empty\n",
        "        if D.get('data') and D['data'].get('states'):\n",
        "            for z in D['data']['states']:\n",
        "                state_data['State_Folder'].append(\"overall_top\")\n",
        "                state_data['Year'].append(year)\n",
        "                state_data['Quarter'].append(quarter_num)\n",
        "                state_data['Top_State_Name'].append(z['entityName'])\n",
        "                state_data['Count'].append(z['metric']['count'])\n",
        "                state_data['Amount'].append(z['metric']['amount'])\n",
        "        else:\n",
        "            # Append None if 'states' data is missing or empty for this quarter\n",
        "            state_data['State_Folder'].append(\"overall_top\")\n",
        "            state_data['Year'].append(year)\n",
        "            state_data['Quarter'].append(quarter_num)\n",
        "            state_data['Top_State_Name'].append(None)\n",
        "            state_data['Count'].append(None)\n",
        "            state_data['Amount'].append(None)\n",
        "\n",
        "        # --- SECTION B: TOP DISTRICTS ---\n",
        "        # Check if 'data' and 'districts' list exist and are not empty\n",
        "        if D.get('data') and D['data'].get('districts'):\n",
        "            for z in D['data']['districts']:\n",
        "                district_data['State_Folder'].append(\"overall_top\")\n",
        "                district_data['Year'].append(year)\n",
        "                district_data['Quarter'].append(quarter_num)\n",
        "                district_data['District_Name'].append(z['entityName'])\n",
        "                district_data['Count'].append(z['metric']['count'])\n",
        "                district_data['Amount'].append(z['metric']['amount'])\n",
        "        else:\n",
        "            # Append None if 'districts' data is missing or empty for this quarter\n",
        "            district_data['State_Folder'].append(\"overall_top\")\n",
        "            district_data['Year'].append(year)\n",
        "            district_data['Quarter'].append(quarter_num)\n",
        "            district_data['District_Name'].append(None)\n",
        "            district_data['Count'].append(None)\n",
        "            district_data['Amount'].append(None)\n",
        "\n",
        "        # --- SECTION C: TOP PINCODES ---\n",
        "        # Check if 'data' and 'pincodes' list exist and are not empty\n",
        "        if D.get('data') and D['data'].get('pincodes'):\n",
        "            for z in D['data']['pincodes']:\n",
        "                pincode_data['State_Folder'].append(\"overall_top\")\n",
        "                pincode_data['Year'].append(year)\n",
        "                pincode_data['Quarter'].append(quarter_num)\n",
        "                pincode_data['Pincode'].append(z['entityName'])\n",
        "                pincode_data['Count'].append(z['metric']['count'])\n",
        "                pincode_data['Amount'].append(z['metric']['amount'])\n",
        "        else:\n",
        "            # Append None if 'pincodes' data is missing or empty for this quarter\n",
        "            pincode_data['State_Folder'].append(\"overall_top\")\n",
        "            pincode_data['Year'].append(year)\n",
        "            pincode_data['Quarter'].append(quarter_num)\n",
        "            pincode_data['Pincode'].append(None)\n",
        "            pincode_data['Count'].append(None)\n",
        "            pincode_data['Amount'].append(None)\n",
        "\n",
        "df_top_states = pd.DataFrame(state_data)\n",
        "df_top_districts = pd.DataFrame(district_data)\n",
        "df_top_pincodes = pd.DataFrame(pincode_data)"
      ]
    },
