        "query = \"\"\"SELECT\n",
        "    \"Year\",\n",
        "    \"Quater\",\n",
        "    SUM(\"Transacion_amount\") AS Total_Transacion_amount\n",
        "FROM aggregated_state_transactions\n",
        "GROUP BY\n",
        "    \"Year\",\n",
        "    \"Quater\"\n",
        "ORDER BY\n",
        "    \"Year\", \"Quater\";\n",
