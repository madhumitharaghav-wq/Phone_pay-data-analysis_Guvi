        "query = \"\"\"SELECT\n",
        "    \"Pincode\",\n",
        "    \"Year\",\n",
        "    \"Quarter\",\n",
        "    SUM(\"Insurance_Count\") AS Top_insurance_count\n",
        "FROM\n",
        "    top_ins_pincodes\n",
        "GROUP BY\n",
        "    \"Pincode\",\n",
        "    \"Year\",\n",
        "    \"Quarter\"\n",
        "ORDER BY\n",
        "    Top_insurance_count DESC\n",
        "LIMIT 10;\n",
        "\"\"\"\n",
        "df_top_insurance_count_pincodesummary = pd.read_sql(query, engine)\n",
