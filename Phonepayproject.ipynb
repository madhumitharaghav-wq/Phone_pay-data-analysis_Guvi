      },
      "outputs": [],
      "source": [
        "clm={'State':[], 'Year':[],'Quater':[],'Region_name':[], 'Registered_Users':[], 'app_opens':[]}\n",
        "\n",
        "for i in Agg_state_list5:\n",
        "    p_i=path+i+\"/\"\n",
        "    Agg_yr5=os.listdir(p_i)\n",
        "    for j in Agg_yr5:\n",
        "        p_j=p_i+j+\"/\"\n",
        "        Agg_yr_list5=os.listdir(p_j)\n",
        "        for k in Agg_yr_list5:\n",
        "            p_k=p_j+k\n",
        "            Data=open(p_k,'r')\n",
        "            D=json.load(Data)\n",
        "            if D.get('data') and D['data'].get('hoverData'):\n",
        "                for region, region_data in D['data']['hoverData'].items():\n",
        "                  reg_users = region_data['registeredUsers']\n",
        "                  app_opens = region_data['appOpens']\n",
        "                  clm['Region_name'].append(region)\n",
        "                  clm['Registered_Users'].append(reg_users)\n",
        "                  clm['app_opens'].append(app_opens)\n",
        "                  clm['State'].append(i)\n",
        "                  clm['Year'].append(j)\n",
        "                  clm['Quater'].append(int(k.strip('.json')))\n",
        "            else:\n",
        "                # If 'hoverData' is not present or empty, append None for all fields to maintain column length\n",
        "                clm['Region_name'].append(None)\n",
        "                clm['Registered_Users'].append(None)\n",
        "                clm['app_opens'].append(None)\n",
        "                clm['State'].append(i)\n",
        "                clm['Year'].append(j)\n",
        "                clm['Quater'].append(int(k.strip('.json')))\n",
        "\n",
        "#Succesfully created a dataframe\n",
        "Map_users=pd.DataFrame(clm)"
      ]
    },
