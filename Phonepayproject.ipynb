      "source": [
        "import pandas as pd\n",
        "import json\n",
        "import os\n",
        "from sqlalchemy import text\n",
        "\n",
        "# Create table if not exists for top_ins_states\n",
        "create_table_sql_top_ins_states = \"\"\"\n",
        "CREATE TABLE IF NOT EXISTS top_ins_states (\n",
        "    country VARCHAR(100) NOT NULL,\n",
        "    year INT NOT NULL,\n",
        "    quarter VARCHAR(2) NOT NULL,\n",
        "    state_name VARCHAR(100) NOT NULL,\n",
        "    insurance_count INT DEFAULT 0,\n",
        "    insurance_amount DECIMAL(18, 2) DEFAULT 0.00,\n",
        "    PRIMARY KEY (country, year, quarter, state_name)\n",
        ");\n",
        "\"\"\"\n",
        "\n",
        "# Create table if not exists for top_ins_districts\n",
        "create_table_sql_top_ins_districts = \"\"\"\n",
        "CREATE TABLE IF NOT EXISTS top_ins_districts (\n",
        "    country VARCHAR(100) NOT NULL,\n",
        "    year INT NOT NULL,\n",
        "    quarter VARCHAR(2) NOT NULL,\n",
        "    district_name VARCHAR(100) NOT NULL,\n",
        "    insurance_count INT DEFAULT 0,\n",
        "    insurance_amount DECIMAL(18, 2) DEFAULT 0.00,\n",
        "    PRIMARY KEY (country, year, quarter, district_name)\n",
        ");\n",
        "\"\"\"\n",
        "\n",
        "# Create table if not exists for top_ins_pincodes\n",
        "create_table_sql_top_ins_pincodes = \"\"\"\n",
        "CREATE TABLE IF NOT EXISTS top_ins_pincodes (\n",
        "    country VARCHAR(100) NOT NULL,\n",
        "    year INT NOT NULL,\n",
        "    quarter VARCHAR(2) NOT NULL,\n",
        "    pincode VARCHAR(20) NOT NULL,\n",
        "    insurance_count INT DEFAULT 0,\n",
        "    insurance_amount DECIMAL(18, 2) DEFAULT 0.00,\n",
        "    PRIMARY KEY (country, year, quarter, pincode)\n",
        ");\n",
        "\"\"\"\n",
        "\n",
        "with engine.connect() as conn:\n",
        "    conn.execute(text(create_table_sql_top_ins_states))\n",
        "    conn.execute(text(create_table_sql_top_ins_districts))\n",
        "    conn.execute(text(create_table_sql_top_ins_pincodes))\n",
        "    conn.commit()\n",
        "\n",
        "# Stream and append the DataFrame data directly into the table\n",
        "df_top_ins_states.to_sql(name=\"top_ins_states\",con=engine,if_exists=\"append\",index=False)\n",
        "df_top_ins_districts.to_sql(name=\"top_ins_districts\",con=engine,if_exists=\"append\",index=False)\n",
        "df_top_ins_pincodes.to_sql(name=\"top_ins_pincodes\",con=engine,if_exists=\"append\",index=False)\n",
        "\n",
        "print(\"Table 'top_ins_states' verified and DataFrame successfully exported to PostgreSQL!\")\n",
        "print(\"Table 'top_ins_districts' verified and DataFrame successfully exported to PostgreSQL!\")\n",
        "print(\"Table 'top_ins_pincodes' verified and DataFrame successfully exported to PostgreSQL!\")\n",
        "\n",
        "# Query the top_transaction_states table to verify the data\n",
        "query = \"SELECT * FROM top_ins_states;\"\n",
        "df_top_ins_states = pd.read_sql(query, engine)\n",
        "\n",
        "query = \"SELECT * FROM top_ins_districts;\"\n",
        "df_top_ins_districts = pd.read_sql(query, engine)\n",
        "\n",
        "query = \"SELECT * FROM top_ins_pincodes;\"\n",
        "df_top_ins_pincodes = pd.read_sql(query, engine)\n",
        "\n",
        "print(\"First 5 rows of the top_transaction_states table in PostgreSQL:\")\n",
        "display(df_top_ins_states.head())\n",
        "display(df_top_ins_districts.head())\n",
        "display(df_top_ins_pincodes.head())"
      ]
    },
