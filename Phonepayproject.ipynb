      "source": [
        "query = \"\"\"\n",
        "    SELECT\n",
        "        \"State\",\n",
        "        \"Year\",\n",
        "        SUM(\"Insurance_count\") AS \"Total_Insurance_Count\",\n",
        "        SUM(\"Insurance_amount\") AS \"Total_Insurance_Amount\"\n",
        "    FROM\n",
        "        insurance_analytics\n",
        "    GROUP BY\n",
        "        \"State\",\n",
        "        \"Year\"\n",
        "    ORDER BY\n",
        "        \"State\" ASC,\n",
        "        \"Year\" ASC;\n",
        "    \"\"\"\n",
        "df_state_wise_insurance_amount = pd.read_sql(query, engine)\n",
