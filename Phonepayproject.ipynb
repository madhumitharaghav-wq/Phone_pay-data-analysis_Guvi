      "source": [
        "query = \"\"\"SELECT\n",
        "    \"Region_name\",\n",
        "    \"Year\",\n",
        "    SUM(\"Transaction_count\") AS \"Total_Transaction_count\"\n",
        "FROM regional_transaction\n",
        "GROUP BY\n",
        "    \"Region_name\",\n",
        "    \"Year\"\n",
        "ORDER BY\n",
        "    \"Total_Transaction_count\" DESC;\n",
        "    \"\"\"\n",
        "df_region_transaction = pd.read_sql(query, engine)\n",
        "\n",
        "display(df_region_transaction)"
      ]
