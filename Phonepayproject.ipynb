        "    state\n",
        "ORDER BY\n",
        "    total_app_opens_for_bottom_users ASC\n",
        "LIMIT 5;\n",
        "    \"\"\"\n",
        "df_statewise_bottom_users = pd.read_sql(query, engine)\n",
        "\n",
        "display(df_statewise_bottom_users)"
      ]
    },
