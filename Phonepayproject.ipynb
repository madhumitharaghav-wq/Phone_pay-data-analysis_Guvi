      "outputs": [],
      "source": [
        "clm={'State':[], 'Year':[],'Quater':[],'Region_name':[], 'Insurance_count':[], 'Insurance_amount':[]}\n",
        "\n",
        "for i in Agg_state_list6:\n",
        "    p_i=path+i+\"/\"\n",
        "    Agg_yr6=os.listdir(p_i)\n",
        "    for j in Agg_yr6:\n",
        "        p_j=p_i+j+\"/\"\n",
        "        Agg_yr_list6=os.listdir(p_j)\n",
        "        for k in Agg_yr_list6:\n",
        "            p_k=p_j+k\n",
        "            Data=open(p_k,'r')\n",
        "            D=json.load(Data)\n",
        "            # Check if 'data' and 'hoverData' exist\n",
        "            if D.get('data') and D['data'].get('hoverDataList'):\n",
        "                # Corrected from hoverDataList and iterating through items\n",
        "               for z in D['data']['hoverDataList']:\n",
        "                   region = z['name']\n",
        "                   count = z['metric'][0]['count']\n",
        "                   amount = z['metric'][0]['amount']\n",
        "               clm['Region_name'].append(region)\n",
        "               clm['Insurance_count'].append(count)\n",
        "               clm['Insurance_amount'].append(amount)\n",
        "               clm['State'].append(i)\n",
        "               clm['Year'].append(j)\n",
        "               clm['Quater'].append(int(k.strip('.json')))\n",
        "\n",
        "#Succesfully created a dataframe\n",
        "Map_insurance=pd.DataFrame(clm)"
      ]
    },
