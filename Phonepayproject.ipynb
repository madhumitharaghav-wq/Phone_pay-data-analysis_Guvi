      "source": [
        "query = \"\"\"SELECT\n",
        "    top_state_name,\n",
        "    year,\n",
        "    SUM(transaction_amount) AS Most_Transaction_Amount\n",
        "FROM\n",
        "    top_transaction_states\n",
        "GROUP BY\n",
        "    top_state_name,\n",
        "    year\n",
        "ORDER BY\n",
        "    Most_Transaction_Amount ASC\n",
        "LIMIT 5;\n",
        "\"\"\"\n",
        "df_Bottom_5_transaction = pd.read_sql(query, engine)\n",
        "\n",
        "display(df_Bottom_5_transaction)"
      ]
