      "source": [
        "query = \"\"\"\n",
        "SELECT\n",
        "    \"State_Name\",\n",
        "    \"Year\",\n",
        "    \"Quarter\",\n",
        "    SUM(\"Insurance_Count\") AS top_insurance_count\n",
        "FROM\n",
        "    top_ins_states\n",
        "GROUP BY\n",
        "    \"State_Name\",\n",
        "    \"Year\",\n",
        "    \"Quarter\"\n",
        "ORDER BY\n",
        "    top_insurance_count DESC\n",
        "LIMIT 10;\n",
        "\"\"\"\n",
        "df_TOP_insurance_count_summary = pd.read_sql(query, engine)\n",
