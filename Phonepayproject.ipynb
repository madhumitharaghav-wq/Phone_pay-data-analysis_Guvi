      "source": [
        "query = \"\"\"\n",
        "WITH RankedUsers AS (\n",
        "    SELECT\n",
        "        state,\n",
        "        app_opens,\n",
        "        registered_users,\n",
        "        ROW_NUMBER() OVER(PARTITION BY state ORDER BY registered_users DESC) as user_rank\n",
        "    FROM\n",
        "        regional_engagement\n",
        ")\n",
        "SELECT\n",
        "    state,\n",
        "    SUM(app_opens) AS total_app_opens_for_top_5_users\n",
        "FROM\n",
        "    RankedUsers\n",
        "WHERE\n",
        "    user_rank <= 5\n",
        "GROUP BY\n",
        "    state\n",
        "ORDER BY\n",
        "    total_app_opens_for_top_5_users DESC\n",
        "LIMIT 5;\n",
        "    \"\"\"\n",
        "df_statewise_Topactive_users = pd.read_sql(query, engine)\n",
        "\n",
        "display(df_statewise_Topactive_users)"
