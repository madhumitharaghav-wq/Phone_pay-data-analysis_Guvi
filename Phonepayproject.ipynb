        "import pandas as pd\n",
        "import json\n",
        "import os\n",
        "from sqlalchemy import text\n",
        "\n",
        "df_top_user_states = pd.DataFrame(top_user_states)\n",
        "df_top_user_districts = pd.DataFrame(top_user_districts)\n",
        "df_top_user_pincodes = pd.DataFrame(top_user_pincodes)\n",
        "\n",
        "# Create table if not exists\n",
        "create_table_sql_states = \"\"\"\n",
        "    CREATE TABLE IF NOT EXISTS top_user_states (\n",
        "        country VARCHAR(100) NOT NULL,\n",
        "        year INT NOT NULL,\n",
        "        quarter VARCHAR(2) NOT NULL, -- e.g., 'Q1', 'Q2'\n",
        "        state_name VARCHAR(100) NOT NULL,\n",
        "        registered_user INT DEFAULT 0,\n",
        "        PRIMARY KEY (country, year, quarter, state_name)\n",
        "    );\n",
        "    \"\"\"\n",
        "create_table_sql_districts = \"\"\"\n",
        "    CREATE TABLE IF NOT EXISTS top_user_districts (\n",
        "        country VARCHAR(100) NOT NULL,\n",
        "        year INT NOT NULL,\n",
        "        quarter VARCHAR(2) NOT NULL,\n",
        "        district_name VARCHAR(100) NOT NULL,\n",
        "        registered_users INT DEFAULT 0,\n",
        "        PRIMARY KEY (country, year, quarter, district_name)\n",
        "    );\n",
        "    \"\"\"\n",
        "create_table_sql_pincodes = \"\"\"\n",
        "    CREATE TABLE pincode_registrations (\n",
        "        country VARCHAR(100) NOT NULL,\n",
        "        year INT NOT NULL,\n",
        "        quarter VARCHAR(2) NOT NULL,\n",
        "        pincode VARCHAR(20) NOT NULL, -- Handles numbers, alphanumeric codes, and leading zeros\n",
        "        registered_users INT DEFAULT 0,\n",
        "        PRIMARY KEY (country, year, quarter, pincode)\n",
        "    );\n",
        "    \"\"\"\n",
        "with engine.connect() as conn:\n",
        "    conn.execute(text(create_table_sql_states))\n",
        "\n",
        "# Stream and append the DataFrame data directly into the table\n",
        "df_top_user_states.to_sql(name=\"top_user_states\",con=engine,if_exists=\"append\",index=False)\n",
        "df_top_user_districts.to_sql(name=\"top_user_districts\",con=engine,if_exists=\"append\",index=False)\n",
        "df_top_user_pincodes.to_sql(name=\"top_user_pincodes\",con=engine,if_exists=\"append\",index=False)\n",
        "\n",
        "print(\"Table 'top_user_states' verified and DataFrame successfully exported to PostgreSQL!\")\n",
        "print(\"Table 'top_user_districts' verified and DataFrame successfully exported to PostgreSQL!\")\n",
        "print(\"Table 'top_user_pincodes' verified and DataFrame successfully exported to PostgreSQL!\")\n",
        "\n",
        "# Query the top_user_states table to verify the data\n",
        "query = \"SELECT * FROM top_user_states;\"\n",
        "df_top_user_states = pd.read_sql(query, engine)\n",
        "\n",
        "query = \"SELECT * FROM top_user_districts;\"\n",
        "df_top_user_districts = pd.read_sql(query, engine)\n",
        "\n",
        "query = \"SELECT * FROM top_user_pincodes;\"\n",
        "df_top_user_pincodes = pd.read_sql(query, engine)\n",
        "\n",
        "print(\"First 5 rows of the top_transaction_states table in PostgreSQL:\")\n",
        "display(df_top_user_states.head())\n",
        "display(df_top_user_districts.head())\n",
        "display(df_top_user_pincodes.head())\n"
      ]
