 \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"transaction_amount\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 450772227237.96436,\n        \"min\": 229267140000.0,\n        \"max\": 1276247100000.0,\n        \"num_unique_values\": 5,\n        \"samples\": [\n          294132840000.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
