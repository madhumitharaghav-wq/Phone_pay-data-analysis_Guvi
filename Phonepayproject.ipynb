        "## 5. Map_users is being created in DataBase"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 321,
      "metadata": {
        "id": "cpq2rYtZ4fpv"
      },
      "outputs": [],
      "source": [
        "from sqlalchemy import text\n",
        "\n",
        "with engine.connect() as conn:\n",
        "    # Drop the table if it exists to ensure a fresh start with correct schema\n",
        "    conn.execute(text(\"DROP TABLE IF EXISTS regional_engagement;\"))\n",
        "    # Commit the drop operation immediately\n",
        "    conn.commit()\n",
        "\n",
        "create_table_sql = \"\"\"\n",
        "    CREATE TABLE regional_engagement (\n",
        "        id SERIAL PRIMARY KEY,\n",
        "        state TEXT NOT NULL,\n",
        "        year INTEGER NOT NULL,\n",
        "        quarter TEXT NOT NULL,\n",
        "        region_name TEXT NOT NULL,\n",
        "        Registered_users INTEGER DEFAULT 0,\n",
        "        app_opens INTEGER DEFAULT 0\n",
        "    );\n",
        "    \"\"\"\n",
        "with engine.connect() as conn:\n",
        "    conn.execute(text(create_table_sql))\n",
        "    # Commit the create table operation\n",
        "    conn.commit()"
      ]
    },
