        "# 6. Map_insurance is being created in DataBase"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 328,
      "metadata": {
        "id": "TTl8Pj1uRAgL"
      },
      "outputs": [],
      "source": [
        "from sqlalchemy import text\n",
        "\n",
        "create_table_sql = \"\"\"\n",
        "CREATE TABLE IF NOT EXISTS map_insurance_data (\n",
        "    id SERIAL PRIMARY KEY,\n",
        "    state VARCHAR(50) NOT NULL,\n",
        "    year INT NOT NULL,\n",
        "    quarter VARCHAR(2) NOT NULL, -- e.g., 'Q1', 'Q2'\n",
        "    region_name VARCHAR(100),\n",
        "    insurance_count INTEGER DEFAULT 0,\n",
        "    insurance_amount REAL DEFAULT 0.0\n",
        ");\n",
        "\"\"\"\n",
        "with engine.connect() as conn:\n",
        "    conn.execute(text(create_table_sql))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 329,
      "metadata": {
        "id": "Pi6MjR66Wp7h",
        "colab": {
