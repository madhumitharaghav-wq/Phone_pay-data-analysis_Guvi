n    {\n      \"column\": \"total_insurance_amount\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 21525351.24409661,\n        \"min\": 20645130.0,\n        \"max\": 90481008.0,\n        \"num_unique_values\": 10,\n        \"samples\": [\n          20945628.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
