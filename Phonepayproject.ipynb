      "source": [
        "query = \"\"\"\n",
        "WITH RankedRegions AS (\n",
        "    SELECT\n",
        "        \"State\",\n",
        "        \"Year\",\n",
        "        \"Quater\",\n",
        "        \"Region_name\",\n",
        "        SUM(\"Insurance_amount\") AS total_insurance_amount,\n",
        "        SUM(\"Insurance_count\") AS total_insurance_count,\n",
        "        DENSE_RANK() OVER(\n",
        "            PARTITION BY \"Year\", \"Quater\"\n",
        "            ORDER BY SUM(\"Insurance_amount\") DESC\n",
        "        ) AS amount_rank\n",
        "    FROM\n",
        "        map_insurance_data\n",
        "    GROUP BY\n",
        "        \"State\",\n",
        "        \"Year\",\n",
        "        \"Quater\",\n",
        "        \"Region_name\"\n",
        ")\n",
        "SELECT\n",
        "    \"State\",\n",
        "    \"Year\",\n",
        "    \"Quater\",\n",
        "    amount_rank,\n",
        "    \"Region_name\",\n",
        "    total_insurance_count,\n",
        "    total_insurance_amount\n",
        "FROM\n",
        "    RankedRegions\n",
        "WHERE\n",
        "    amount_rank <= 10\n",
        "ORDER BY\n",
        "    \"Year\" DESC,\n",
        "    \"Quater\" ASC,\n",
        "    amount_rank ASC\n",
        "LIMIT 10;\n",
        "\"\"\"\n",
        "\n",
        "df_top_regions = pd.read_sql(query, engine)\n",
        "display(df_top_regions)"
      ]
    },
