    {
      "cell_type": "markdown",
      "metadata": {
        "id": "hcKVQbA90P_e"
      },
      "source": [
        "3.3 Top 10 states / districts / pin codes where the most number of the insurance happened for a selected year-quarter combination."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 298,
      "metadata": {
        "id": "XFMwyDHdAjML"
      },
      "outputs": [],
      "source": [
        "\n",
        "\n",
        "# 1. Update your base path to point to the Top Insurance directory\n",
        "base_path = \"/content/pulse/data/top/insurance/country/india/\"\n",
        "\n",
        "# 2. Initialize three separate dictionaries for different geographic layers\n",
        "top_ins_states = {'Country': [], 'Year': [], 'Quarter': [], 'State_Name': [], 'Insurance_Count': [], 'Insurance_Amount': []}\n",
        "top_ins_districts = {'Country': [], 'Year': [], 'Quarter': [], 'District_Name': [], 'Insurance_Count': [], 'Insurance_Amount': []}\n",
        "top_ins_pincodes = {'Country': [], 'Year': [], 'Quarter': [], 'Pincode': [], 'Insurance_Count': [], 'Insurance_Amount': []}\n",
        "\n",
        "# Get year directories dynamically\n",
        "year_directories = [d for d in os.listdir(base_path) if os.path.isdir(os.path.join(base_path, d)) and d.isdigit()]\n",
        "\n",
        "# 3. Loop through your national insurance records\n",
        "for year in year_directories:\n",
        "    year_path = os.path.join(base_path, year)\n",
        "\n",
        "    # Get the quarter json files directly inside the year folder\n",
        "    quarter_json_files = [f for f in os.listdir(year_path) if f.endswith('.json') and f.replace('.json', '').isdigit()]\n",
        "\n",
        "    for quarter_file in quarter_json_files:\n",
        "        full_file_path = os.path.join(year_path, quarter_file)\n",
        "        quarter_num = int(quarter_file.replace('.json', ''))\n",
        "\n",
        "        with open(full_file_path, 'r') as f:\n",
        "            D = json.load(f)\n",
        "\n",
        "            # Safe check to see if 'data' block exists\n",
        "            if D.get('data'):\n",
        "                data_block = D['data']\n",
        "\n",
        "                # --- SECTION A: TOP INSURANCE STATES ---\n",
        "                if data_block.get('states'):\n",
        "                    for z in data_block['states']:\n",
        "                        top_ins_states['Country'].append('India')\n",
        "                        top_ins_states['Year'].append(int(year))\n",
        "                        top_ins_states['Quarter'].append(quarter_num)\n",
        "                        top_ins_states['State_Name'].append(z['entityName'])\n",
        "                        # Direct access: Metric is a direct dictionary, no loop index needed\n",
        "                        top_ins_states['Insurance_Count'].append(z['metric']['count'])\n",
        "                        top_ins_states['Insurance_Amount'].append(z['metric']['amount'])\n",
        "\n",
        "                # --- SECTION B: TOP INSURANCE DISTRICTS ---\n",
        "                if data_block.get('districts'):\n",
        "                    for z in data_block['districts']:\n",
        "                        top_ins_districts['Country'].append('India')\n",
        "                        top_ins_districts['Year'].append(int(year))\n",
        "                        top_ins_districts['Quarter'].append(quarter_num)\n",
        "                        top_ins_districts['District_Name'].append(z['entityName'])\n",
        "                        top_ins_districts['Insurance_Count'].append(z['metric']['count'])\n",
        "                        top_ins_districts['Insurance_Amount'].append(z['metric']['amount'])\n",
        "\n",
        "                # --- SECTION C: TOP INSURANCE PINCODES ---\n",
        "                if data_block.get('pincodes'):\n",
        "                    for z in data_block['pincodes']:\n",
        "                        top_ins_pincodes['Country'].append('India')\n",
        "                        top_ins_pincodes['Year'].append(int(year))\n",
        "                        top_ins_pincodes['Quarter'].append(quarter_num)\n",
        "                        top_ins_pincodes['Pincode'].append(z['entityName'])\n",
        "                        top_ins_pincodes['Insurance_Count'].append(z['metric']['count'])\n",
        "                        top_ins_pincodes['Insurance_Amount'].append(z['metric']['amount'])\n",
        "\n",
        "# 4. Convert all three mapped dictionaries into separate pandas DataFrames\n",
        "df_top_ins_states = pd.DataFrame(top_ins_states)\n",
        "df_top_ins_districts = pd.DataFrame(top_ins_districts)\n",
        "df_top_ins_pincodes = pd.DataFrame(top_ins_pincodes)\n"
      ]
    },
